# Dashboard data source. Copy to `.env.local` to override the live defaults.
#
# The API origin. Unset -> the deployed Render service.
# For local backend dev: http://localhost:8000
VITE_API_BASE=https://periapsis-platform.onrender.com

# The tenant whose evidence to show, sent as X-Org-Id (dev-stub auth for now).
# Unset -> the public demo org.
VITE_ORG_ID=9d9a129f-e476-40c9-b9ba-6d95276dacdb

# Dashboard data source. Copy to `.env.local` to override the default.
#
# The API origin. Unset -> the deployed Render service.
# For local backend dev: http://localhost:8000
VITE_API_BASE=https://periapsis-platform.onrender.com

# Auth is per-session in the browser: choose "View demo" (no key) or paste an
# API key on the login screen. There is no key in env — it's never built into
# the shipped site.
